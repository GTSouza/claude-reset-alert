# Credenciais do Telegram (opcional) para receber as notificações.
# Copie este arquivo para .env e preencha com seus valores:
#   cp .env.example .env
#
# Token do bot, obtido com o @BotFather (https://t.me/BotFather).
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234567890

# chat_id de destino. Pode ser um usuário, um grupo (número negativo),
# um canal (@canal) ou vários separados por vírgula: 123,-100456,@canal
# Descubra o seu rodando: ./claude-limit-watch.sh getid
TELEGRAM_CHAT_ID=123456789

# Os nomes TG_TOKEN / TG_CHAT_ID também funcionam, se preferir.
